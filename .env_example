THINGSPEAK_API_KEY=your_thingspeak_api_key
THINGSPEAK_CHANNEL_ID=your_thingspeak_channel_id
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
AIR_QUALITY_THRESHOLD=your_air_quality_threshold
AIR_QUALITY_NIGHT_THRESHOLD=your_air_quality_threshold
TEMPERATURE_THRESHOLD=30
CRON_EXPRESSION=*/5 * * * *

# AC control via M5StickC
M5_STICK_IP=192.168.1.XXX        # IP M5StickC в локальной сети (или имя accontrol.local)
AC_TEMPERATURE_THRESHOLD=28      # при этой температуре включить кондиционер
AC_TEMPERATURE_RESTORE=24        # при этой температуре выключить (гистерезис)

